{
  "rules": {
    ".read": false,
    ".write": false,
    "live": {
      ".read": "auth != null",
      "$id": {
        ".write": "auth != null && auth.uid === $id && !data.child('source').exists() && !newData.child('source').exists()",
        ".validate": "newData.hasChildren(['lat','lng','ts'])",
        "lat": { ".validate": "newData.isNumber()" },
        "lng": { ".validate": "newData.isNumber()" },
        "ts":  { ".validate": "newData.isNumber()" }
      }
    },
    "torch": {
      ".read": "auth != null",
      ".write": false
    },
    "community": {
      ".read": "auth != null",
      ".write": false
    }
  }
}
